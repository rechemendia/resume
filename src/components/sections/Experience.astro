---
import Section from "../Section.astro"
import { useTranslations } from "@/i18n/utils"

const { work, lang } = Astro.props
const t = useTranslations(lang)
---

<Section title={t('section.experience')}>
  <ul>
    {
      work.map(
        ({ name, startDate, endDate, position, summary, highlights, url }) => {
          const startYear = new Date(startDate).getFullYear()
          const endYear =
            endDate != null ? new Date(endDate).getFullYear() : t('work.present')

          // Separar las tecnologías de los highlights
          const techHighlight = highlights?.find(h => h.toLowerCase().startsWith('technologies') || h.toLowerCase().startsWith('tecnologías'))
          const pureHighlights = highlights?.filter(h => h !== techHighlight)

          return (
            <li>
              <article>
                <header>
                  <div>
                    <h3>
                      <a href={url} title={`Ver ${name}`} target="_blank">
                        {name}
                      </a>
                    </h3>
                    <h4>{position}</h4>
                  </div>

                  <div class="date">
                    <time datetime={startDate}>{startYear}</time>
                    {" - "}
                    <time datetime={endDate}>{endYear}</time>
                  </div>
                </header>

                <footer>
                  <p>{summary}</p>
                  {
                    pureHighlights && pureHighlights.length > 0 && (
                      <ul class="highlights">
                        {pureHighlights.map((highlight) => (
                          <li>
                            <span>{highlight}</span>
                          </li>
                        ))}
                      </ul>
                    )
                  }
                  {
                    techHighlight && (
                      <div class="technologies">
                        <strong>{t('work.technologies')}:</strong> {techHighlight.split(':')[1]}
                      </div>
                    )
                  }
                </footer>
              </article>
            </li>
          )
        }
      )
    }
  </ul>
</Section>

<style>
  ul {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  article h3 {
    font-weight: 600;
    color: #111;
    font-size: 1.1rem;
  }

  article a {
    color: #111;
  }

  article a:hover {
    text-decoration: underline;
  }

  article h4 {
    color: #444;
    font-weight: 500;
    font-size: 0.95rem;
    margin: 0;
  }

  header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 8px;
  }

  .date {
    text-align: right;
    color: #666;
    font-size: 0.85rem;
    min-width: 102px;
  }

  footer p {
    color: #555;
    margin-bottom: 12px;
  }

  .highlights {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-top: 12px;
    padding-left: 0;
  }

  .highlights li {
    color: #444;
    font-size: 0.85rem;
    line-height: 1.4;
    position: relative;
    padding-left: 1.2rem;
  }

  .highlights li::before {
    content: "•";
    position: absolute;
    left: 0;
    color: #999;
    font-size: 1.1rem;
  }

  .technologies {
    margin-top: 16px;
    font-size: 0.8rem;
    color: #666;
    line-height: 1.5;
    background: #fdfdfd;
    padding: 8px 12px;
    border-radius: 6px;
    border: 1px solid #f0f0f0;
  }

  .technologies strong {
    color: #333;
    font-weight: 600;
  }

  @media (width <= 700px) {
    .date {
      text-align: left;
    }
    header {
      flex-direction: column;
      gap: 8px;
    }
  }
</style>
