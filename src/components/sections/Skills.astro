---
import Section from "../Section.astro"
import { useTranslations } from "@/i18n/utils"

const { skills, lang } = Astro.props
const t = useTranslations(lang)
---

<Section title={t('section.skills')}>
  <ul class="main-list">
    {
      skills.map(({ name, keywords }) => (
        <li>
          <div class="skill-category">
            <strong>{name}</strong>
            <ul class="keywords-list">
              {keywords.map(keyword => (
                <li>{keyword}</li>
              ))}
            </ul>
          </div>
        </li>
      ))
    }
  </ul>
</Section>

<style>
  .main-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .skill-category {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .skill-category strong {
    color: #333;
    font-size: 0.95rem;
    font-weight: 600;
  }

  .keywords-list {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .keywords-list li {
    border-radius: 6px;
    background: #f2f2f2;
    color: #444;
    font-size: 0.75rem;
    font-weight: 500;
    padding: 0.2rem 0.6rem;
    transition: all 0.2s ease;
  }

  .keywords-list li:hover {
    background: #e8e8e8;
    color: #000;
  }
</style>
